# unh 环境变量目录结构（见 unh.config.ts：root=envs, usePlatformDir=true）
#
# envs/
# ├── h5/
# │   ├── .env                 # 平台共享变量
# │   ├── .env.development
# │   ├── .env.staging
# │   └── .env.production
# ├── mp-weixin/
# └── app/
#
# 复制对应平台目录下的文件并按需修改。
# 本地覆盖：envs/{platform}/.env.local 或 .env.{mode}.local（*.local 已 gitignore）

# --- 共享变量（envs/{platform}/.env）---
VITE_APP_NAME=uniapp-wot-template
VITE_APP_TITLE=Uniapp Wot Template
VITE_API_TIMEOUT=15000

# --- H5 开发（envs/h5/.env.development）---
# VITE_API_BASE_URL=/dev-api
# VITE_API_PROXY_MAP=[["/dev-api","http://localhost:8080","/api"]]
# VITE_USE_MOCK=true
# VITE_ENV_NAME=development

# --- 小程序/App 开发（envs/mp-weixin|app/.env.development）---
# VITE_API_BASE_URL=https://your-api.example.com/api
# VITE_USE_MOCK=true
# VITE_ENV_NAME=development

# 类型声明：unh prepare 或 dev/build 后自动生成 types/env.d.ts
