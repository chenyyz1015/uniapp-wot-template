{
  "name": "uniapp-wot-template",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "基于 Uniapp + Vue 3 + TypeScript 的企业级移动端项目模板，集成 Wot UI、Pinia、Uni Network 与 AI 开发工具配置",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0 <21.0.0"
  },
  "scripts": {
    "dev": "unh dev",
    "dev:app": "unh dev app",
    "dev:app-android": "unh dev app-android",
    "dev:app-ios": "unh dev app-ios",
    "dev:custom": "unh dev",
    "dev:h5": "unh dev h5",
    "dev:h5:ssr": "unh dev h5 --ssr",
    "dev:h5:development": "unh dev h5 --mode development",
    "dev:h5:staging": "unh dev h5 --mode staging",
    "dev:h5:production": "unh dev h5 --mode production",
    "dev:mp-alipay": "unh dev mp-alipay",
    "dev:mp-baidu": "unh dev mp-baidu",
    "dev:mp-kuaishou": "unh dev mp-kuaishou",
    "dev:mp-lark": "unh dev mp-lark",
    "dev:mp-qq": "unh dev mp-qq",
    "dev:mp-toutiao": "unh dev mp-toutiao",
    "dev:mp-weixin": "unh dev mp-weixin",
    "dev:wx": "unh dev wx",
    "dev:quickapp-webview": "unh dev quickapp-webview",
    "dev:quickapp-webview-huawei": "unh dev quickapp-webview-huawei",
    "dev:quickapp-webview-union": "unh dev quickapp-webview-union",
    "build": "unh build",
    "build:app": "unh build app",
    "build:app-android": "unh build app-android",
    "build:app-ios": "unh build app-ios",
    "build:custom": "unh build",
    "build:h5": "unh build h5",
    "build:h5:ssr": "unh build h5 --ssr",
    "build:h5:development": "unh build h5 --mode development",
    "build:h5:staging": "unh build h5 --mode staging",
    "build:h5:production": "unh build h5 --mode production",
    "build:mp-alipay": "unh build mp-alipay",
    "build:mp-baidu": "unh build mp-baidu",
    "build:mp-kuaishou": "unh build mp-kuaishou",
    "build:mp-lark": "unh build mp-lark",
    "build:mp-qq": "unh build mp-qq",
    "build:mp-toutiao": "unh build mp-toutiao",
    "build:mp-weixin": "unh build mp-weixin",
    "build:quickapp-webview": "unh build quickapp-webview",
    "build:quickapp-webview-huawei": "unh build quickapp-webview-huawei",
    "build:quickapp-webview-union": "unh build quickapp-webview-union",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,vue}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,vue}\"",
    "lint": "eslint . && prettier --check \"src/**/*.{js,jsx,ts,tsx,vue}\" && stylelint \"src/**/*.{css,scss,vue}\"",
    "lint:fix": "eslint . --fix && prettier --write \"src/**/*.{js,jsx,ts,tsx,vue}\" && stylelint \"src/**/*.{css,scss,vue}\" --fix",
    "prepare": "husky && unh prepare",
    "rebuild:skills-symlinks": "powershell -ExecutionPolicy Bypass -File scripts/setup-ai-skills-symlinks.ps1",
    "rebuild:commands-symlinks": "powershell -ExecutionPolicy Bypass -File scripts/setup-ai-commands-symlinks.ps1"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080520251106001",
