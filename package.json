    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "vue": "~3.4.38",
    "vue-i18n": "^9.14.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@dcloudio/types": "^3.4.12",
    "@dcloudio/uni-automator": "3.0.0-4080520251106001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080520251106001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080520251106001",
    "@dcloudio/uni-vue-devtools": "3.0.0-4020420240722002",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080520251106001",
    "@iconify/utils": "^3.1.4",
    "@mini-types/alipay": "^3.0.14",
    "@types/node": "^20.16.2",
    "@uni-helper/eslint-config": "^0.5.0",
    "@uni-helper/plugin-uni": "^0.1.0",
    "@uni-helper/unh": "^0.3.1",
    "@uni-helper/uni-env": "^0.2.0",
    "@uni-helper/uni-types": "1.0.1",
    "@uni-helper/unocss-preset-uni": "^0.2.11",
    "@uni-helper/vite-plugin-uni-components": "^0.2.6",
    "@uni-helper/vite-plugin-uni-layouts": "^0.1.11",
    "@uni-helper/vite-plugin-uni-manifest": "^0.2.12",
    "@uni-helper/vite-plugin-uni-pages": "^0.3.23",
    "@uni-helper/vite-plugin-uni-platform": "^0.1.2",
    "@uni-helper/volar-service-uni-pages": "^0.3.23",
    "@uni-ku/root": "^1.4.1",
    "@unocss/eslint-config": "^66.5.6",
    "@unocss/preset-legacy-compat": "^66.7.2",
    "@vue/runtime-core": "^3.4.38",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "miniprogram-api-typings": "^3.12.3",
    "postcss-html": "^1.8.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.5.4",
    "unocss": "66.0.0",
    "unocss-applet": "^0.12.2",
    "unplugin-auto-import": "^0.18.2",
    "vite": "^5.2.8",
    "vue-tsc": "^2.0.29"
  },
  "lint-staged": {
    "src/**/*.vue": [
      "prettier --write",
      "eslint --fix",
      "stylelint --fix"
    ],
    "src/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{css,scss}": "stylelint --fix"
  }
}
